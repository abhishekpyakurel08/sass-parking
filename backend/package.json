{
  "name": "parksaas-backend",
  "version": "1.0.0",
  "description": "Production-grade Multi-Tenant Parking SaaS Backend",
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec tsx src/app.ts",
    "build": "tsc --project tsconfig.json && mkdir -p dist/config && cp src/config/swagger.yaml dist/config/swagger.yaml",
    "start": "node dist/app.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.2.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.2",
    "morgan": "^1.10.1",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "qrcode": "^1.5.4",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.17.0",
    "xss-clean": "^0.1.4",
    "yamljs": "^0.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/hpp": "^0.2.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.1",
    "@types/node-cache": "^4.1.3",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34",
    "nodemon": "^3.1.14",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
